script-source,79,/Volumes/External_SSD/Documentos/Projects/maiajs/compiler/parse-tree-collector.js,class ParseTreeCollector {\n  constructor() {\n    this.stack = [];\n    this.root = null;\n  }\n\n  parse(parser\x2C inputLabel = 'input') {\n    if (!parser || typeof parser.parse !== 'function') {\n      throw new Error('ParseTreeCollector.parse requires a parser instance with parse()');\n    }\n\n    const inputText = parser.lexer && typeof parser.lexer.input === 'string'\n      ? parser.lexer.input\n      : '';\n\n    try {\n      return parser.parse();\n    } catch (err) {\n      const message = err && err.message ? err.message : String(err);\n      const offset = extractOffsetFromError(err\x2C parser);\n      if (offset === null || inputText.length === 0) {\n        throw new Error(`Parse failed for ${inputLabel}: ${message}`);\n      }\n\n      const loc = offsetToLineColumn(inputText\x2C offset);\n      throw new Error(\n        `Parse failed for ${inputLabel}: ${message} at line ${loc.line}\x2C column ${loc.column} (offset ${loc.offset})`\n      );\n    }\n  }\n\n  checkpoint() {\n    // Hot path: parser backtracking calls checkpoint/restore very frequently.\n    // A full structuredClone of the whole tree causes severe quadratic\n    // behavior on ambiguous inputs. We only need enough state to rollback\n    // mutations performed after this checkpoint.\n    return {\n      stackLength: this.stack.length\x2C\n      root: this.root\x2C\n      childLengths: this.stack.map((node) =>\n        Array.isArray(node && node.children) ? node.children.length : 0\n      )\n    };\n  }\n\n  restore(mark) {\n    if (!mark) return;\n\n    const targetLen = Number.isInteger(mark.stackLength) ? mark.stackLength : 0;\n    const childLengths = Array.isArray(mark.childLengths) ? mark.childLengths : [];\n\n    const sharedLen = Math.min(this.stack.length\x2C childLengths.length\x2C targetLen);\n    for (let i = 0; i < sharedLen; i += 1) {\n      const node = this.stack[i];\n      if (node && Array.isArray(node.children)) {\n        node.children.length = childLengths[i];\n      }\n    }\n\n    if (this.stack.length > targetLen) {\n      this.stack.length = targetLen;\n    }\n\n    this.root = Object.prototype.hasOwnProperty.call(mark\x2C 'root') ? mark.root : this.root;\n  }\n\n  startNonterminal(name) {\n    this.stack.push({ kind: 'nonterminal'\x2C name\x2C children: [] });\n  }\n\n  terminal(expectedType\x2C tokenValue) {\n    if (this.stack.length === 0) return;\n    const parent = this.stack[this.stack.length - 1];\n    parent.children.push({\n      kind: 'terminal'\x2C\n      token: expectedType\x2C\n      value: tokenValue\n    });\n  }\n\n  endNonterminal() {\n    const node = this.stack.pop();\n    if (!node) return;\n\n    if (this.stack.length === 0) {\n      this.root = node;\n    } else {\n      this.stack[this.stack.length - 1].children.push(node);\n    }\n  }\n\n  abortNonterminal() {\n    this.stack.pop();\n  }\n\n  toJSON(space = 2) {\n    return JSON.stringify(this.root\x2C null\x2C space);\n  }\n\n  toXml(options = {}) {\n    if (!this.root) {\n      throw new Error('No parse tree was collected from parser events');\n    }\n\n    const includeDeclaration = options.includeDeclaration !== false;\n    const xmlBody = serializeNodeAsXml(this.root);\n    return includeDeclaration\n      ? `<?xml version="1.0" encoding="UTF-8"?>${xmlBody}`\n      : xmlBody;\n  }\n}\n\nfunction offsetToLineColumn(text\x2C offset) {\n  const safeOffset = Math.max(0\x2C Math.min(Number(offset) || 0\x2C text.length));\n  let line = 1;\n  let column = 1;\n\n  for (let i = 0; i < safeOffset; i++) {\n    const ch = text[i];\n    if (ch === '\\r') {\n      if (text[i + 1] === '\\n') {\n        i++;\n      }\n      line++;\n      column = 1;\n    } else if (ch === '\\n') {\n      line++;\n      column = 1;\n    } else {\n      column++;\n    }\n  }\n\n  return { line\x2C column\x2C offset: safeOffset };\n}\n\nfunction extractOffsetFromError(err\x2C parser) {\n  if (parser && Array.isArray(parser.tokens) && Number.isInteger(parser.position)) {\n    const token = parser.tokens[parser.position] || null;\n    if (token && Number.isInteger(token.start)) {\n      return token.start;\n    }\n  }\n\n  const message = err && err.message ? String(err.message) : '';\n  const match = message.match(/\\b(?:position|offset)\\s+(\\d+)\\b/i);\n  if (match) {\n    return Number(match[1]);\n  }\n\n  return null;\n}\n\nfunction xmlEscape(value) {\n  return String(value)\n    .replace(/&/g\x2C '&amp;')\n    .replace(/</g\x2C '&lt;')\n    .replace(/>/g\x2C '&gt;');\n}\n\nfunction terminalElementName(tokenType) {\n  if (tokenType === 'EOF') return 'EOF';\n  return tokenType.startsWith('TOKEN_') ? 'TOKEN' : tokenType;\n}\n\nfunction serializeNodeAsXml(node) {\n  if (!node) return '';\n\n  if (node.kind === 'terminal') {\n    const elementName = terminalElementName(node.token);\n    if (node.token === 'EOF') {\n      return `<${elementName}/>`;\n    }\n    return `<${elementName}>${xmlEscape(node.value)}</${elementName}>`;\n  }\n\n  const children = Array.isArray(node.children) ? node.children : [];\n  if (children.length === 0) {\n    return `<${node.name}/>`;\n  }\n\n  const inner = children.map((child) => serializeNodeAsXml(child)).join('');\n  return `<${node.name}>${inner}</${node.name}>`;\n}\n\nfunction getNodeLabel(node) {\n  if (!node) return '(null)';\n  if (node.kind === 'terminal') {\n    return `${node.token}: ${JSON.stringify(node.value)}`;\n  }\n  return node.name;\n}\n\nfunction printTree(node\x2C prefix = ''\x2C isLast = true\x2C isRoot = true) {\n  if (!node) return;\n\n  const branch = isRoot ? '' : isLast ? '\u2514\u2500 ' : '\u251c\u2500 ';\n  console.log(prefix + branch + getNodeLabel(node));\n\n  if (!Array.isArray(node.children) || node.children.length === 0) {\n    return;\n  }\n\n  const childPrefix = isRoot ? '' : prefix + (isLast ? '   ' : '\u2502  ');\n  for (let index = 0; index < node.children.length; index++) {\n    const child = node.children[index];\n    const childIsLast = index === node.children.length - 1;\n    printTree(child\x2C childPrefix\x2C childIsLast\x2C false);\n  }\n}\n\nmodule.exports = {\n  ParseTreeCollector\x2C\n  printTree\x2C\n  getNodeLabel\n};\n
